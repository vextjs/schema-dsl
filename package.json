{
  "name": "schema-dsl",
  "version": "2.1.6",
  "description": "Progressive TypeScript schema DSL for concise, serializable field rules, validation, schema reuse, database/Markdown export, i18n, and runtime isolation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pure": {
      "import": {
        "types": "./dist/pure.d.ts",
        "default": "./dist/pure.js"
      },
      "require": {
        "types": "./dist/pure.d.cts",
        "default": "./dist/pure.cjs"
      }
    },
    "./compat": {
      "import": {
        "types": "./dist/compat.d.ts",
        "default": "./dist/compat.js"
      },
      "require": {
        "types": "./dist/compat.d.cts",
        "default": "./dist/compat.cjs"
      }
    },
    "./register-string": {
      "import": {
        "types": "./dist/register-string.d.ts",
        "default": "./dist/register-string.js"
      },
      "require": {
        "types": "./dist/register-string.d.cts",
        "default": "./dist/register-string.cjs"
      }
    },
    "./string-types": {
      "import": {
        "types": "./dist/string-types.d.ts",
        "default": "./dist/string-types.js"
      },
      "require": {
        "types": "./dist/string-types.d.cts",
        "default": "./dist/string-types.cjs"
      }
    },
    "./transform": {
      "import": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "require": {
        "types": "./dist/transform.d.cts",
        "default": "./dist/transform.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.ts",
        "default": "./dist/esbuild.js"
      },
      "require": {
        "types": "./dist/esbuild.d.cts",
        "default": "./dist/esbuild.cjs"
      }
    },
    "./plugins/custom-format": {
      "import": {
        "types": "./dist/plugins/custom-format.d.ts",
        "default": "./dist/plugins/custom-format.js"
      },
      "require": {
        "types": "./dist/plugins/custom-format.d.cts",
        "default": "./dist/plugins/custom-format.cjs"
      }
    },
    "./plugins/custom-validator": {
      "import": {
        "types": "./dist/plugins/custom-validator.d.ts",
        "default": "./dist/plugins/custom-validator.js"
      },
      "require": {
        "types": "./dist/plugins/custom-validator.d.cts",
        "default": "./dist/plugins/custom-validator.cjs"
      }
    },
    "./plugins/custom-type-example": {
      "import": {
        "types": "./dist/plugins/custom-type-example.d.ts",
        "default": "./dist/plugins/custom-type-example.js"
      },
      "require": {
        "types": "./dist/plugins/custom-type-example.d.cts",
        "default": "./dist/plugins/custom-type-example.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude test/unit/performance.test.ts",
    "test:types": "tsc -p tsconfig.test-types.source-no-opt-in.json --noEmit && tsc -p tsconfig.test-types.source-opt-in.json --noEmit && tsc -p tsconfig.test-types.package-no-opt-in.json --noEmit && tsc -p tsconfig.test-types.package-opt-in.json --noEmit",
    "typecheck": "tsc --noEmit",
    "examples:typecheck": "tsc -p tsconfig.examples.json --noEmit",
    "examples:build": "tsc -p tsconfig.examples.json",
    "examples:run": "npm run examples:build && node scripts/run-doc-examples.mjs",
    "docs:linkcheck": "node scripts/check-doc-links.mjs",
    "docs:performance-check": "node scripts/check-performance-docs.mjs",
    "lint": "eslint src/**/*.ts",
    "test:audit": "npm audit --omit=dev --audit-level=moderate",
    "test:audit:all": "npm audit --audit-level=moderate",
    "test:interop": "node scripts/verify-esm-cjs-type-registry.mjs",
    "test:package": "node scripts/verify-packed-consumer.mjs",
    "test:version": "node -e \"const p=require('./package.json');const {VERSION}=require('./dist/index.cjs');if(p.version!==VERSION)throw new Error('Version mismatch: '+p.version+' vs '+VERSION);console.log('Version OK:',p.version)\"",
    "test:all:with-audit": "npm run lint && npm run build && npm run test:interop && npm run typecheck && npm run test:types && npm test && npm run test:version && npm run test:audit && npm run test:audit:all && npm run docs:performance-check && npm run docs:linkcheck && npm run test:package",
    "bench:prepare": "npm run build --silent",
    "bench": "npm run bench:prepare && node test/benchmarks/library-comparison.js",
    "bench:zod": "npm run bench:prepare && node test/benchmarks/zod-scenario-matrix.js --json",
    "bench:conditional": "npm run bench:prepare && node test/benchmarks/conditional-regression.js --json",
    "bench:smoke": "npm run bench:prepare && node test/benchmarks/library-comparison.js --smoke --json && node test/benchmarks/entry-matrix.js --smoke --json && node test/benchmarks/zod-scenario-matrix.js --smoke --json",
    "bench:full": "npm run bench:prepare && node test/benchmarks/library-comparison.js --json && node test/benchmarks/entry-matrix.js --json && node test/benchmarks/zod-scenario-matrix.js --json",
    "bench:cache": "npm run bench:prepare && node test/benchmarks/cache-stability.js --json",
    "bench:guard:smoke": "npm run bench:prepare && node scripts/check-performance-regression.mjs",
    "bench:guard:full": "npm run bench:prepare && node scripts/check-performance-regression.mjs --full",
    "prepublishOnly": "npm run test:all:with-audit && npm pack --dry-run"
  },
  "keywords": [
    "schema",
    "validation",
    "validator",
    "dsl",
    "json-schema",
    "data-validation",
    "form-validation",
    "mongodb",
    "mysql",
    "postgresql",
    "database-schema",
    "i18n",
    "internationalization",
    "typescript",
    "express",
    "koa",
    "fastify",
    "rest-api",
    "input-validation"
  ],
  "author": "rocky <rockyshi1993@gmail.com>",
  "license": "Apache-2.0",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs",
    "./dist/compat.js",
    "./dist/compat.cjs",
    "./dist/register-string.js",
    "./dist/register-string.cjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vextjs/schema-dsl.git"
  },
  "bugs": {
    "url": "https://github.com/vextjs/schema-dsl/issues"
  },
  "homepage": "https://vextjs.github.io/schema-dsl",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "2.1.1",
    "cache-hub": "2.2.4",
    "json5": "2.2.3",
    "safe-regex": "2.1.1"
  },
  "peerDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "esbuild": "^0.28.1"
  },
  "peerDependenciesMeta": {
    "@babel/generator": {
      "optional": true
    },
    "@babel/parser": {
      "optional": true
    },
    "@babel/traverse": {
      "optional": true
    },
    "@babel/types": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "3.2.6",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "fastest-validator": "1.19.1",
    "joi": "17.13.4",
    "tinybench": "2.9.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.6",
    "yup": "1.7.1",
    "zod": "4.3.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "5.2.1"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
